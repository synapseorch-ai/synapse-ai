# ─────────────────────────────────────────────────────────────────────────────
# Synapse AI — Docker Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env before running docker compose:
#   cp .env.docker .env
#   docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# Internal token for frontend↔backend security.
# Leave BLANK: on first boot the containers auto-generate a random token and
# share it via the `synapse-secrets` volume, so the backend's /api/* surface is
# never left unauthenticated (GHSA-3j67-x3j8-r32x). Set an explicit value only
# if you want to pin the token yourself: openssl rand -hex 32
#
# The backend port is bound to 127.0.0.1 in docker-compose.yml — do NOT publish
# it on 0.0.0.0. For the single-image `docker run`, publish only port 3000
# (the frontend); enable login for any network-reachable deployment.
SYNAPSE_INTERNAL_TOKEN=

# Ports (change if you have conflicts)
SYNAPSE_BACKEND_PORT=8765
SYNAPSE_FRONTEND_PORT=3000

# Host interface the backend port binds to. Default 127.0.0.1 (loopback only):
# the frontend proxies the backend over the internal network, and the open
# /api/v1|v2 API is reachable at http://host:${SYNAPSE_FRONTEND_PORT}/api/v1/...
# Set to 0.0.0.0 ONLY if you need to hit the backend directly from other hosts
# (e.g. external API clients pointed straight at :8765). Safe because the
# internal token auto-generates, but leave as loopback unless you need it.
SYNAPSE_BACKEND_BIND=127.0.0.1

# Ollama URL (for local LLM inference)
# Use http://host.docker.internal:11434 on Docker Desktop (Mac/Windows)
# Use http://host-gateway:11434 on Linux
OLLAMA_BASE_URL=http://host-gateway:11434

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider API Keys (add the ones you use)
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# GROK_API_KEY=xai-...
# DEEPSEEK_API_KEY=...

# ─────────────────────────────────────────────────────────────────────────────
# Scale profile (docker compose --profile scale up)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: shared Postgres for worker state and definitions
# SCALE_POSTGRES_URL=postgresql://user:pass@host:5432/synapse

# Worker tuning
# WORKER_CONCURRENCY=10
# WORKER_JOB_TIMEOUT=3600
# WORKER_MAX_RETRIES=3
# NUM_QUEUE_SHARDS=1

# Multi-tenancy
# DEFAULT_TENANT_ID=default
# ENABLE_TENANT_ISOLATION=0

# PgBouncer (set to 1 if using PgBouncer in transaction mode)
# PGBOUNCER_MODE=0

# S3 storage for vault + execution logs (optional)
# S3_BUCKET=my-synapse-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_ENDPOINT_URL=            # MinIO / Cloudflare R2 / etc.

# Observability (optional)
# OTLP_ENDPOINT=http://jaeger:4317
# METRICS_TOKEN=

# Pull pre-built worker image from Docker Hub instead of building locally
# DOCKERHUB_USERNAME=synapseorchai
# SYNAPSE_VERSION=latest
