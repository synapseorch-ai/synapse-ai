# ─────────────────────────────────────────────────────────────────────────────
# Synapse AI — Docker Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env before running docker compose:
#   cp .env.docker .env
#
# Then generate an internal token:
#   openssl rand -hex 32
# and paste it below.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: Internal token for frontend↔backend security.
# Generate with: openssl rand -hex 32
SYNAPSE_INTERNAL_TOKEN=

# Ports (change if you have conflicts)
SYNAPSE_BACKEND_PORT=8765
SYNAPSE_FRONTEND_PORT=3000

# Ollama URL (for local LLM inference)
# Use http://host.docker.internal:11434 on Docker Desktop (Mac/Windows)
# Use http://host-gateway:11434 on Linux
OLLAMA_BASE_URL=http://host-gateway:11434

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider API Keys (add the ones you use)
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# GROK_API_KEY=xai-...
# DEEPSEEK_API_KEY=...

# ─────────────────────────────────────────────────────────────────────────────
# Scale profile (docker compose --profile scale up)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: shared Postgres for worker state and definitions
# SCALE_POSTGRES_URL=postgresql://user:pass@host:5432/synapse

# Worker tuning
# WORKER_CONCURRENCY=10
# WORKER_JOB_TIMEOUT=3600
# WORKER_MAX_RETRIES=3
# NUM_QUEUE_SHARDS=1

# Multi-tenancy
# DEFAULT_TENANT_ID=default
# ENABLE_TENANT_ISOLATION=0

# PgBouncer (set to 1 if using PgBouncer in transaction mode)
# PGBOUNCER_MODE=0

# S3 storage for vault + execution logs (optional)
# S3_BUCKET=my-synapse-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_ENDPOINT_URL=            # MinIO / Cloudflare R2 / etc.

# Observability (optional)
# OTLP_ENDPOINT=http://jaeger:4317
# METRICS_TOKEN=

# Pull pre-built worker image from Docker Hub instead of building locally
# DOCKERHUB_USERNAME=synapseorchai
# SYNAPSE_VERSION=latest
