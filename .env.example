# Synapse - Environment Configuration
# Copy this file to .env and fill in your values.
# All values are optional — Synapse works with defaults.

# Directory where Synapse stores user data (settings, agent configs, vault, logs)
# Default: backend/data  (relative to the project root)
SYNAPSE_DATA_DIR=backend/data

# Ollama base URL (for local models)
# Default: http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Port for the backend API server
# Default: 8765
SYNAPSE_BACKEND_PORT=8765

# Port for the frontend web UI
# Default: 3000
SYNAPSE_FRONTEND_PORT=3000

# Backend port exposed to the Next.js browser bundle (used in UI instructions like Google OAuth redirect URI)
# Must match SYNAPSE_BACKEND_PORT. Requires a frontend rebuild when changed.
# Default: 8765
NEXT_PUBLIC_BACKEND_PORT=8765

# Backend URL as seen by the Next.js server (used in Docker / custom deployments).
# OPTIONAL — if omitted, auto-derived from SYNAPSE_BACKEND_PORT as http://127.0.0.1:<port>.
# Override here for Docker/remote deployments (e.g. http://synapse-backend:8765).
# BACKEND_URL=http://synapse-backend:8765

# CORS origins allowed by the backend (comma-separated)
# Default: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000

# Coding Agent default db configuration
# Default: postgres://postgres:password@localhost:5432/synapse
DATABASE_URL=postgres://postgres:root@localhost:5432/synapse

# ── Timeouts (optional) ───────────────────────────────────────────────────────
# All timeouts are in seconds unless noted. Each falls back to the value shown
# when unset, so leaving these blank keeps the previous behavior. Raise them for
# slow networks or slow local models; lower them to fail fast.

# MCP session read timeout — max wait for any MCP request (default: 60)
# SYNAPSE_MCP_SESSION_READ_TIMEOUT=60

# MCP tool-call timeout — max wait for a single MCP tool invocation (default: 60)
# SYNAPSE_MCP_TOOL_CALL_TIMEOUT=60

# MCP list_tools timeout — max wait when discovering a server's tools (default: 15)
# SYNAPSE_MCP_LIST_TOOLS_TIMEOUT=15

# LLM request timeout — per-attempt timeout for cloud LLM API calls (default: 180)
# SYNAPSE_LLM_TIMEOUT=180

# HTTP custom-tool timeout — max wait for a custom HTTP/webhook tool call (default: 30)
# SYNAPSE_HTTP_TOOL_TIMEOUT=30

# Orchestration per-step default timeout — used when a step sets none (default: 300)
# SYNAPSE_ORCH_STEP_TIMEOUT=300

# Orchestration global default timeout in MINUTES — used when a workflow sets none (default: 30)
# SYNAPSE_ORCH_GLOBAL_TIMEOUT_MINUTES=30

# Orchestration human-input default timeout — wait for a human/messaging reply (default: 3600)
# SYNAPSE_ORCH_HUMAN_TIMEOUT=3600
